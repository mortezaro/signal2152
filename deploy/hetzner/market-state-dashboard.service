[Unit]
Description=Market State Dashboard API
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/opt/market-state-dashboard/backend
EnvironmentFile=/opt/market-state-dashboard/backend/.env
ExecStart=/opt/market-state-dashboard/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
